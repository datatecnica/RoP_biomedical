# RoP build artifacts
dist/
build/
*.egg-info/
*.egg

# Staged source data — generated by orchestrator or user-supplied,
# not part of the repo content
data/sources/*/
!data/sources/*/.gitkeep

# Foundation pipeline staging — derived from sources, not version-controlled
data/foundation/staging/*
!data/foundation/staging/.gitkeep

# Boutique CDEs — user-supplied, confidential project data
data/boutique/
boutique-May4th2026/

# Final bundle staging — large files for Zenodo release
data/final/

# Bundle outputs — go to S3/Zenodo, not GitHub
dist/rop_v*/

# Checkpoint files from long-running GPU jobs
*_checkpoint.npz

# Log files
*.log
embedding*.txt
faiss*.log


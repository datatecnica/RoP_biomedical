    "member_of_collections": ["RoP-Core"],
    "curation_status": "expert-curated"
  },
  {
    "item": "AnatomicalRegionCode",
    "description": "Identifier in the chosen AnatomicalRegionVocabulary. Examples: 'UBERON:0002038' (substantia nigra), 'UBERON:0013540' (Brodmann area 9), 'AllenBrainAtlas:SNc' (substantia nigra pars compacta).",
    "collection": "RoP-Core-Biosample-Anatomy",
    "item_type": "string",
    "values": null,
    "alternate_names": "RegionCode|AnatomyID",

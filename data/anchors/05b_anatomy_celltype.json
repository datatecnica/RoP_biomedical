  {
    "item": "CellType",
    "description": "Free-text or labeled cell type when the biosample is a cell-level isolate or population (FACS-sorted, single-cell, magnetically separated, organoid-derived). Examples: 'dopaminergic neuron, A9 group', 'microglia, IBA1+', 'CD4+ memory T cell'.",
    "collection": "RoP-Core-Biosample-Cell",
    "item_type": "string",
    "values": null,
    "alternate_names": "CellPopulation|CellIdentity",
    "priority": "Required-for-cell-isolate-biosamples",
    "metadata_": { "max_length": 512, "free_text": true, "ground_truth": true,
                   "companion_fields": ["CellTypeVocabulary", "CellTypeCode"] },
    "source_authority": "DataTecnica-derived",
    "source_version": "RoP-2026.04",
    "member_of_collections": ["RoP-Core"],
    "curation_status": "expert-curated"
  },
  {
    "item": "CellTypeVocabulary",
    "description": "Controlled vocabulary used for the CellTypeCode. Default Cell Ontology (CL); BICCN-CCN required for single-cell-defined types not yet in CL (e.g., dopaminergic subtypes from Kamath 2022, AD microglia subtypes).",
    "collection": "RoP-Core-Biosample-Cell",
    "item_type": "enum",
    "values": "CL|BICCN-CCN|PCL|Other|NotApplicable",
    "alternate_names": "CellTypeOntology",
    "priority": "Required-when-CellTypeCode-present",
    "metadata_": { "default": "CL",
                   "fallback_order": ["CL", "BICCN-CCN", "PCL"],
                   "notes": "BICCN-CCN preferred when transcriptomically-defined subtypes are needed" },

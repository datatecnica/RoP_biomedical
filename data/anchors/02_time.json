    "collection": "RoP-Core-Time",
    "item_type": "date",
    "values": "YYYY-MM[-DD]",
    "alternate_names": "BaselineDate|EnrollmentDate|StudyEntryDate",
    "priority": "Required",
    "metadata_": {
      "format": "ISO-8601-partial",
      "phi": true,
      "anchor": true
    },
    "source_authority": "DataTecnica-derived",
    "source_version": "RoP-2026.04",
    "member_of_collections": [
      "RoP-Core"
    ],
    "curation_status": "expert-curated"
  },
  {
    "item": "VisitDate",
    "description": "Calendar date the study visit was conducted.",
    "collection": "RoP-Core-Time",
    "item_type": "date",
    "values": "YYYY-MM-DD",
    "alternate_names": "VisitDt|DateOfVisit",
    "priority": "Required-or-derivable",
    "metadata_": {
      "format": "ISO-8601",
      "anchor": true,
      "transform_rule": "if absent, derive from VisitBaselineDate + YearsFromEnrollment * 365.25"
    },
    "source_authority": "LOINC",
    "source_code": "11778-8",
    "source_version": "LOINC-2.78",
    "member_of_collections": [
      "RoP-Core"
    ],
    "curation_status": "expert-curated"
  },
  {
    "item": "VisitNumber",
    "description": "Sequential visit identifier within the study; 0 = baseline/screening visit.",
    "collection": "RoP-Core-Time",
    "item_type": "numeric",
    "values": "0..200",
    "alternate_names": "VisitNum|VisitSeq|VisitIndex",
    "priority": "Required-or-derivable",
    "metadata_": {
      "anchor": true,
      "baseline_value": 0,
      "increment": 1,
      "transform_rule": "rank-order by VisitDate within SubjectID; 0-indexed"
    },
    "source_authority": "DataTecnica-derived",
    "source_version": "RoP-2026.04",
    "member_of_collections": [
      "RoP-Core"
    ],
    "curation_status": "expert-curated",
    "unit_of_measure": "1",
    "unit_vocabulary": "UCUM",
    "plausible_min": 0,
    "plausible_max": 1000
  },
  {
    "item": "YearsFromEnrollment",
    "description": "Time elapsed between this visit and VisitBaselineDate, expressed as a float in years. Supports fractional values (0.25 = ~3 months).",
    "collection": "RoP-Core-Time",
    "item_type": "numeric",
    "values": "0.0..50.0",
    "alternate_names": "YearsFromBaseline|TimeSinceEnrollment|FollowUpYears",
    "priority": "Required-or-derivable",
    "metadata_": {
      "unit": "years",
      "precision": 2,
      "anchor": true,
      "transform_rule": "(VisitDate - VisitBaselineDate) / 365.25"
    },
    "source_authority": "DataTecnica-derived",
    "source_version": "RoP-2026.04",
    "member_of_collections": [
      "RoP-Core"
    ],
